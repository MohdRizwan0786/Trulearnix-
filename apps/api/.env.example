# =============================================
# TruLearnix API — Environment Variables
# Copy: cp .env.example .env  then fill values
# =============================================

PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://localhost:27017/trulearnix

# JWT
JWT_SECRET=change_me_strong_random_secret_32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_strong_refresh_secret_32chars
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=trulearnix-media

# SMTP (Email)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=official@trulearnix.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=TruLearnix <official@trulearnix.com>

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_ACCOUNT_NUMBER=your_razorpayx_account_number
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# PhonePe
PHONEPE_CLIENT_ID=your_phonepe_client_id
PHONEPE_CLIENT_SECRET=your_phonepe_client_secret
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=PRODUCTION
PHONEPE_CALLBACK_USERNAME=your_callback_username
PHONEPE_CALLBACK_PASSWORD=your_callback_password

# WhatsApp (WATI)
WHATSAPP_API_URL=https://api.wati.io/api/v1
WHATSAPP_API_TOKEN=your_wati_token

# Meta WhatsApp Cloud API (used by Nova agent / whatsappMetaService)
META_PHONE_NUMBER_ID=your_meta_phone_number_id
META_WABA_ID=your_whatsapp_business_account_id
META_WHATSAPP_TOKEN=your_meta_permanent_access_token
META_WA_VERIFY_TOKEN=your_webhook_verify_token

# App URLs — change per environment
WEB_URL=https://trulearnix.com
ADMIN_URL=https://admin.trulearnix.com

# Affiliate
AFFILIATE_COMMISSION_RATE=10

# Certificate
CERTIFICATE_SECRET=change_me_cert_secret_32chars

# LiveKit (Self-hosted)
LIVEKIT_URL=wss://livekit.trulearnix.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret_min32chars

# Web Push VAPID (generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@trulearnix.com
